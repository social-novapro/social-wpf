<UserControl x:Class="social_wpf.Controls.PostCardControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Background="White"
            BorderBrush="#E2E2E2"
            BorderThickness="1"
            CornerRadius="10"
            Padding="14"
            Margin="0,0,0,12">

        <StackPanel>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="48"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Width="40"
                        Height="40"
                        CornerRadius="20"
                        Background="#DDD"
                        VerticalAlignment="Top">
                    <Image x:Name="AvatarImage"
                           Stretch="UniformToFill"/>
                </Border>

                <StackPanel Grid.Column="1"
                            Margin="10,0,0,0">

                    <TextBlock x:Name="UsernameTextBlock"
                               FontWeight="Bold"
                               FontSize="14"/>

                    <TextBlock x:Name="ContentTextBlock"
                               TextWrapping="Wrap"
                               FontSize="14"
                               Margin="0,5,0,0"/>

                    <WrapPanel x:Name="AttachmentsPanel"
                               Margin="0,10,0,0"/>

                    <TextBlock x:Name="MetaTextBlock"
                               Foreground="Gray"
                               FontSize="11"
                               Margin="0,10,0,0"/>
                </StackPanel>
            </Grid>
        </StackPanel>
    </Border>
</UserControl>