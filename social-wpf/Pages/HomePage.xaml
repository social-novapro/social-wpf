<Page x:Class="social_wpf.Pages.HomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="HomePage">

    <Grid Background="#F4F4F5" Margin="18">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="150"/>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="170"/>
        </Grid.ColumnDefinitions>

        <!-- Composer -->
        <Border Grid.Column="0"
                Background="White"
                CornerRadius="10"
                Padding="16"
                Margin="0,0,14,0">

            <StackPanel>
                <TextBlock Text="Create Post"
                           FontSize="18"
                           FontWeight="Bold"
                           Margin="0,0,0,10"/>

                <TextBox x:Name="PostTextBox"
                         Height="130"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         Padding="8"/>

                <Button x:Name="QueuePostButton"
                        Content="Queue Post"
                        Height="36"
                        Margin="0,12,0,0"
                        Click="QueuePostButton_Click"/>

                <TextBlock x:Name="PostStatusTextBlock"
                           Foreground="Gray"
                           TextWrapping="Wrap"
                           Margin="0,10,0,0"/>
            </StackPanel>
        </Border>

        <!-- Feed -->
        <Border Grid.Column="1"
                Background="White"
                CornerRadius="10"
                Padding="16"
                Margin="0,0,14,0">

            <DockPanel>
                <TextBlock DockPanel.Dock="Top"
                           Text="Feed"
                           FontSize="20"
                           FontWeight="Bold"
                           Margin="0,0,0,14"/>

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="FeedStackPanel"/>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- Thread Monitor -->
        <Border Grid.Column="2"
                Background="White"
                CornerRadius="10"
                Padding="16">

            <DockPanel>
                <TextBlock DockPanel.Dock="Top"
                           Text="Thread Monitor"
                           FontSize="18"
                           FontWeight="Bold"
                           Margin="0,0,0,12"/>

                <StackPanel>
                    <TextBlock x:Name="SummaryTextBlock"
                               Foreground="Gray"
                               TextWrapping="Wrap"
                               Margin="0,0,0,14"/>

                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="ThreadStatusStackPanel"/>
                    </ScrollViewer>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Page>